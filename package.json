{
  "name": "programistok-meetup",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Landing + prezentacja meetup — niezależny od monorepo (docelowo osobne repo).",
  "scripts": {
    "build": "node --import tsx scripts/build.ts",
    "test": "node node_modules/vitest/vitest.mjs run",
    "preview": "npx --yes serve dist -p 8788",
    "pages:dev": "npx --yes wrangler pages dev dist",
    "pages:deploy": "npm run build && npx --yes wrangler pages deploy dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.4"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^15.0.4"
  }
}
